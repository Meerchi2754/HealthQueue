generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int     @unique @default(autoincrement())
  name        String
  email       String  @unique
  password    String
  phonenumber String?
  role        Role    @default(PATIENT)
}

enum Role {
  PATIENT
  ADMIN
  DOCTOR
}
